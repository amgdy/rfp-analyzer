{
    "$schema": "https://schema.management.azure.com/schemas/2019-04-01/deploymentParameters.json#",
    "contentVersion": "1.0.0.0",
    "parameters": {
      "environmentName": {
        "value": "${AZURE_ENV_NAME}"
      },
      "location": {
        "value": "${AZURE_LOCATION}"
      },
      "foundryLocation": {
        "value": "${AZURE_FOUNDRY_LOCATION=${AZURE_LOCATION}}"
      },
      "rfpAnalyzerExists": {
        "value": "${SERVICE_RFP_ANALYZER_RESOURCE_EXISTS=false}"
      }
    }
}
