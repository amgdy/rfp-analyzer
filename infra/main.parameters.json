{
    "$schema": "https://schema.management.azure.com/schemas/2019-04-01/deploymentParameters.json#",
    "contentVersion": "1.0.0.0",
    "parameters": {
      "environmentName": {
        "value": "${AZURE_ENV_NAME}"
      },
      "location": {
        "value": "${AZURE_LOCATION}"
      },
      "foundryLocation": {
        "value": "${AZURE_FOUNDRY_LOCATION}"
      },
      "reasoningModelName": {
        "value": "${AZURE_REASONING_MODEL_NAME=gpt-5.4}"
      },
      "reasoningModelVersion": {
        "value": "${AZURE_REASONING_MODEL_VERSION=2026-03-05}"
      },
      "principalId": {
        "value": "${AZURE_PRINCIPAL_ID}"
      },
      "rfpAnalyzerExists": {
        "value": "${SERVICE_RFP_ANALYZER_RESOURCE_EXISTS=false}"
      }
    }
}
