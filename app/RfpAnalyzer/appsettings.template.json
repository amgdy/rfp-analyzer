{
  // ============================================================================
  // RFP Analyzer - Application Settings Template
  // ============================================================================
  //
  // AUTHENTICATION:
  //   This application uses Azure DefaultAzureCredential for ALL Azure service
  //   authentication. NO API keys, secrets, or connection strings are needed.
  //
  //   - In Azure (production): Uses Managed Identity (system or user-assigned)
  //   - Locally: Uses Azure CLI credentials (run 'az login' first)
  //   - In CI/CD: Uses environment credentials or workload identity
  //
  //   See: https://learn.microsoft.com/en-us/dotnet/api/azure.identity.defaultazurecredential
  //
  // SETUP:
  //   1. Copy this file to appsettings.Development.json (for local dev)
  //   2. Replace placeholder values with your Azure resource endpoints
  //   3. Ensure you have 'az login' authenticated to the correct subscription
  //   4. Ensure your identity has the required RBAC roles (see below)
  //
  // REQUIRED RBAC ROLES:
  //   - "Azure AI Developer" on the Azure OpenAI / AI Foundry resource
  //   - "Cognitive Services User" on the Content Understanding resource
  //   - "Cognitive Services User" on the Document Intelligence resource
  //
  // ============================================================================

  // ---------------------------------------------------------------------------
  // Azure OpenAI / AI Foundry
  // ---------------------------------------------------------------------------
  // The endpoint URL for your Azure OpenAI or AI Foundry resource.
  // Example: "https://your-resource-name.openai.azure.com/"
  "AZURE_OPENAI_ENDPOINT": "https://<your-openai-resource>.openai.azure.com/",

  // The deployment name for the chat completion model (used for scoring & comparison agents).
  // Example: "gpt-4o-mini", "gpt-4.1", "gpt-5.2"
  "AZURE_OPENAI_DEPLOYMENT_NAME": "<your-deployment-name>",

  // ---------------------------------------------------------------------------
  // Azure Content Understanding (for document extraction)
  // ---------------------------------------------------------------------------
  // The endpoint URL for your Azure Content Understanding resource.
  // Example: "https://your-resource-name.cognitiveservices.azure.com/"
  "AZURE_CONTENT_UNDERSTANDING_ENDPOINT": "https://<your-content-understanding-resource>.cognitiveservices.azure.com/",

  // ---------------------------------------------------------------------------
  // Azure Document Intelligence (alternative extraction service)
  // ---------------------------------------------------------------------------
  // The endpoint URL for your Azure Document Intelligence resource.
  // Example: "https://your-resource-name.cognitiveservices.azure.com/"
  "AZURE_DOCUMENT_INTELLIGENCE_ENDPOINT": "https://<your-document-intelligence-resource>.cognitiveservices.azure.com/",

  // ---------------------------------------------------------------------------
  // Azure Managed Identity (optional, for user-assigned identity in Azure)
  // ---------------------------------------------------------------------------
  // When running in Azure Container Apps with a user-assigned managed identity,
  // set this to the client ID of that identity. Leave empty for system-assigned
  // identity or local development.
  "AZURE_CLIENT_ID": "",

  // ---------------------------------------------------------------------------
  // Application Insights / OpenTelemetry (optional, for production monitoring)
  // ---------------------------------------------------------------------------
  // Connection string for Azure Application Insights. Set automatically by
  // infrastructure when deployed via 'azd up'. Leave empty for local dev.
  "APPLICATIONINSIGHTS_CONNECTION_STRING": "",

  // ---------------------------------------------------------------------------
  // Logging
  // ---------------------------------------------------------------------------
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },

  "AllowedHosts": "*"
}
